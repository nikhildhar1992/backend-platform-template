# Used when running API + worker inside Docker (see docker-compose.yml)
# Copy to .env.docker or docker-compose loads it via env_file

PORT=5000
NODE_ENV=development

# Docker service names (same Compose network)
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Nikhil@123
DB_NAME=backend_template

# BullMQ queue — same Redis; host is service name `redis`
REDIS_URL=redis://redis:6379

# Set to "true" only if you want user-list caching via Redis (optional)
ENABLE_REDIS_CACHE=false

JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=1d

GEMINI_API_KEY=AIzaSyDT0p-rOgdNn6ahH7lQUKwgxtbo6TMi5_0
GEMINI_LLM_MODEL=gemini-2.0-flash
